# PFFT Miner Config — GPU Edition

# Ethereum RPC endpoint
ETH_RPC=https://ethereum-rpc.publicnode.com

# Your EVM private key (hex, with or without 0x prefix)
PRIVATE_KEY=your_private_key_here

# ── GPU Settings ──────────────────────────────────────────────────────────────
# Backend: auto | cuda | opencl | cpu
# Default: auto (deteksi otomatis, prioritas CUDA > OpenCL > CPU)
# BACKEND=cuda

# Jumlah hash per GPU launch (default: 4_000_000)
# Naikkan jika GPU kamu punya banyak VRAM, turunkan jika crash
# GPU_BATCH=4000000

# ── CPU Fallback ──────────────────────────────────────────────────────────────
# Jumlah CPU core (hanya dipakai jika tidak ada GPU)
# NUM_WORKERS=8
